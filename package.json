{
  "name": "rodlauncher",
  "version": "0.1.0",
  "description": "RodLauncher, um launcher Electron moderno para Minecraft Java em modo local/demo.",
  "main": ".vite/build/index.js",
  "author": "RodLauncher contributors",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "release": "electron-forge publish"
  },
  "dependencies": {
    "@xmcl/core": "latest",
    "@xmcl/installer": "latest",
    "dotenv": "latest",
    "framer-motion": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "skinview3d": "latest"
  },
  "devDependencies": {
    "@electron-forge/cli": "latest",
    "@electron-forge/maker-deb": "latest",
    "@electron-forge/maker-rpm": "latest",
    "@electron-forge/maker-squirrel": "latest",
    "@electron-forge/maker-zip": "latest",
    "@electron-forge/plugin-auto-unpack-natives": "latest",
    "@electron-forge/plugin-vite": "latest",
    "@electron-forge/publisher-github": "^7.11.2",
    "@electron-forge/shared-types": "latest",
    "@eslint/js": "latest",
    "@tailwindcss/vite": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "@vitejs/plugin-react": "latest",
    "electron": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
