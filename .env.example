# Opcional: caminho absoluto para o Java que o RodLauncher deve usar.
# Windows:
# RODLAUNCHER_JAVA=C:\Program Files\Eclipse Adoptium\jdk-21\bin\java.exe
#
# Linux/macOS:
# RODLAUNCHER_JAVA=/usr/bin/java

# Opcional: pasta de Minecraft extra para o launcher verificar antes de baixar.
# Se vazio, ele verifica a pasta do RodLauncher e a .minecraft oficial do sistema.
# RODLAUNCHER_MINECRAFT_DIR=C:\Users\rodri\AppData\Roaming\.minecraft
